ANTHROPIC_API_KEY=your_key_here
BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
RESULTS_DIR=./results
HF_TOKEN=your_hf_token_if_needed

# Which model the METRICS (rollouts) run on. MUST be `qwen` for a valid result:
# xLift must measure the same model GRPO trains, or the score↔lift correlation
# compares two different models. Default is `claude` (cheap laptop dev only).
# NOTE: GEPA is intentionally left on Claude (PoC); the other rollout metrics honor this.
XLIFT_BACKEND=qwen
